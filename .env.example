# Vietnam Real Estate Web Crawler - Environment Configuration
# Copy this file to .env and update values as needed

# ===========================
# DATABASE SETTINGS
# ===========================
DATABASE_PATH=/root/clawd/EstatePredictor/data/estate_crawler.db
LOG_DIR=/root/clawd/EstatePredictor/logs
DATA_DIR=/root/clawd/EstatePredictor/data

# ===========================
# REQUEST SETTINGS
# ===========================
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
RETRY_DELAY=5
RATE_LIMIT_DELAY=2

# ===========================
# SCHEDULER SETTINGS
# ===========================
SCHEDULER_ENABLED=True
SCHEDULER_INTERVAL_HOURS=48

# ===========================
# LOGGING
# ===========================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===========================
# PROXY SETTINGS (Optional)
# ===========================
# Use proxies to avoid IP blocking
# PROXY_URL=http://proxy.example.com:8080
# PROXY_USERNAME=username
# PROXY_PASSWORD=password

# ===========================
# NOTIFICATION SETTINGS (Optional)
# ===========================
# Send notifications when crawling completes
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# EMAIL_NOTIFICATIONS=False
# EMAIL_RECIPIENTS=admin@example.com

# ===========================
# HEADLESS BROWSER (for Selenium)
# ===========================
SELENIUM_HEADLESS=True
SELENIUM_IMPLICIT_WAIT=10
SELENIUM_PAGE_LOAD_TIMEOUT=30

# ===========================
# FEATURE FLAGS
# ===========================
ENABLE_JAVASCRIPT_RENDERING=False
ENABLE_IMAGE_DOWNLOADING=False
ENABLE_CONTACT_EXTRACTION=True
